{
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.1",
    "allure-playwright": "^3.6.0",
    "playwright": "^1.58.2"
  },
  "scripts": {
    "tests": "npx playwright test",
    "headed": "npx playwright test --headed --project=chrome",
    "debug": "npx playwright test --debug --project=chrome",
    "chrome": "npx playwright test --project=chrome",
    "webkit": "npx playwright test --project=webkit",
    "firefox": "npx playwright test --project=firefox",
    "mobile": "npx playwright test --project=mobileChrome",
    "allure": "cp -r allure-report/history allure-results/ && allure generate allure-results --clean && allure open ./allure-report",
    "allure_clean": "rm -rf allure-results/*"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "faker-br": "^0.5.0",
    "pwmochawesome": "^2.0.2"
  }
}
